# ── Weather provider ────────────────────────────────────────────────────────
# Defaults to Open-Meteo (free, no key required). Only set these to switch.
# VITE_WEATHER_PROVIDER=open-meteo
# VITE_WEATHER_PROVIDER=weatherapi   (requires VITE_WEATHER_API_KEY)
# VITE_WEATHER_API_KEY=

# ── Firebase (Firestore) ─────────────────────────────────────────────────────
# All four vars are required to activate Firestore sync.
# Without them the app works fully — data stays in localStorage only.
#
# MVP NOTE: The app uses Firestore keyed by normalized email address (no Firebase
# Auth). This is intentional for closed beta. For public launch, enable Firebase
# Auth and update Firestore security rules to enforce ownership by email.
# See src/lib/cloudSync.ts for the security comment in the Firestore path.
#
# Firestore security rules for MVP (open — trusted users only):
#   rules_version = '2';
#   service cloud.firestore {
#     match /databases/{database}/documents {
#       match /users/{emailKey}/{document=**} {
#         allow read, write: if true;
#       }
#     }
#   }
#
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Setting this switches premium.tsx from the local demo trial toggle to real
# Stripe Checkout. Also requires a server route (/api/create-checkout-session).
# See src/lib/billing.ts for exactly what's prepared vs. still needed.
# VITE_STRIPE_PUBLISHABLE_KEY=
